{
  "name": "angelin-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:dev:refresh": "dotenv -e .env.development.local -- npx prisma db push && dotenv -e .env.development.local -- npx prisma db seed",
    "db:push:local": "dotenv -e .env.development.local -- node scripts/db-safe-push.js local",
    "db:push:staging": "dotenv -e .env.staging.safe -- node scripts/db-safe-push.js staging",
    "db:push:prod": "dotenv -e .env.production.safe -- node scripts/db-safe-push.js prod",
    "db:push:prod:confirm": "CONFIRM_PROD_DB=YES_PROD dotenv -e .env.production.safe -- node scripts/db-safe-push.js prod",
    "dev:local": "npm run db:dev:refresh && npm run dev",
    "release": "git push origin master && git push vercel master"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@fontsource/pinyon-script": "^5.2.8",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@react-email/components": "^1.0.10",
    "@react-pdf/renderer": "^4.3.2",
    "@supabase/supabase-js": "^2.99.3",
    "browser-image-compression": "^2.0.2",
    "googleapis": "^171.4.0",
    "lucide-react": "^0.577.0",
    "next": "16.2.3",
    "next-auth": "^4.24.13",
    "nodemailer": "^7.0.13",
    "pg": "^8.20.0",
    "prisma": "^7.5.0",
    "react": "^18",
    "react-dom": "^18",
    "zod": "^4.3.6"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.18.0",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/react-pdf": "^6.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "bcryptjs": "^3.0.3",
    "dotenv-cli": "^11.0.0",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "jsdom": "^29.0.0",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.0"
  }
}
