generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Client {
  id           String        @id @default(cuid())
  name         String
  phone        String        @unique
  email        String?
  createdAt    DateTime      @default(now())
  appointments Appointment[]
  skinProfile  SkinProfile?
}

model SkinProfile {
  id                   String   @id @default(cuid())
  clientId             String   @unique
  fecha                DateTime
  edad                 Int?
  fototipo             String?
  biotipo              String?
  sensibilidad         String?
  hidratacion          String?
  grosorPiel           String?
  alteracionesCutaneas String?
  elasticidad          String?
  resistencias         String?
  pigmentaciones       String?
  vitalidadOxigenacion String?
  habitos              String?
  embarazo             String?
  exposicionSolar      String?
  deporte              String?
  enfermedades         String?
  medicamentos         String?
  apoyoEnCasa          String?
  comentarios          String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  client               Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model Appointment {
  id                       String            @id @default(cuid())
  clientId                 String
  service                  String
  date                     DateTime
  status                   AppointmentStatus @default(CONFIRMED)
  sessionNotes             String?
  gcalEventId              String?
  whatsappConfirmationSent Boolean           @default(false)
  whatsappReminderSent     Boolean           @default(false)
  pricePaid                Float?
  paymentMethod            String?
  createdAt                DateTime          @default(now())
  client                   Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  inventoryLogs            InventoryLog[]
}

enum AppointmentStatus {
  CONFIRMED
  COMPLETED
  CANCELLED
}

model Service {
  id              String           @id @default(cuid())
  name            String
  category        String
  duration        String
  price           String
  description     String?
  isActive        Boolean          @default(true)
  costIngredients Float?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  serviceProducts ServiceProduct[]
}

model Product {
  id              String           @id @default(cuid())
  name            String           @unique
  brand           String?
  unit            String
  capacityPerUnit Float
  costPerUnit     Float
  stock           Float            @default(0)
  lowStockAlert   Float            @default(1)
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  serviceProducts ServiceProduct[]
  inventoryLogs   InventoryLog[]
}

model ServiceProduct {
  id          String  @id @default(cuid())
  serviceId   String
  productId   String
  quantityUsed Float
  service     Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  product     Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([serviceId, productId])
}

model InventoryLog {
  id            String      @id @default(cuid())
  productId     String
  appointmentId String?
  delta         Float
  reason        String
  createdAt     DateTime    @default(now())
  product       Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  appointment   Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
}
